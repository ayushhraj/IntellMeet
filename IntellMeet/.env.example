# ============================================
# IntellMeet Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/intellmeet

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OpenAI (for AI features - optional, mock mode if not set)
OPENAI_API_KEY=your-openai-api-key

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (for media storage - optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WebRTC STUN/TURN
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
